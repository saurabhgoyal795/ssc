# ====================================
# SSC EXAM PLATFORM - PRODUCTION ENV
# ====================================

# ============================================================================
# BACKEND ENVIRONMENT VARIABLES (Railway)
# ============================================================================

# Database Configuration (Auto-set by Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:password@host:5432/railway
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-db-password
DATABASE_NAME=railway

# JWT Configuration (CRITICAL - Change these!)
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-256-BIT-RANDOM-KEY-USE-openssl-rand-base64-32
# Generate with: openssl rand -base64 32

# AWS S3 Configuration (Required for file uploads)
AWS_ACCESS_KEY=your-aws-access-key-id
AWS_SECRET_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ssc-exam-files-prod
AWS_CLOUDFRONT_DOMAIN=  # Optional: your-cdn.cloudfront.net

# CORS Configuration (Update with your Vercel domain)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Email Configuration (Optional but recommended)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=noreply@sscexam.com
EMAIL_VERIFICATION_URL=https://your-app.vercel.app/verify-email
EMAIL_RESET_PASSWORD_URL=https://your-app.vercel.app/reset-password

# Server Configuration
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES (Vercel)
# ============================================================================

# API URL (Point to your Railway backend)
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api/v1

# ============================================================================
# OPTIONAL CONFIGURATIONS
# ============================================================================

# Razorpay (if enabling payments later)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Redis (if enabling later)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================

# Backend (Railway):
# 1. ✅ Created Railway project
# 2. ✅ Added PostgreSQL database
# 3. ✅ Deployed backend service
# 4. ✅ Set all environment variables above
# 5. ✅ Verified deployment logs
# 6. ✅ Tested API health endpoint

# Frontend (Vercel):
# 1. ✅ Imported GitHub repository
# 2. ✅ Set NEXT_PUBLIC_API_URL
# 3. ✅ Deployed successfully
# 4. ✅ Tested registration/login

# AWS S3:
# 1. ✅ Created S3 bucket
# 2. ✅ Configured CORS
# 3. ✅ Created IAM user with S3 access
# 4. ✅ Added credentials to Railway

# Post-Deployment:
# 1. ✅ Updated CORS_ORIGINS with Vercel URL
# 2. ✅ Updated S3 CORS with Vercel URL
# 3. ✅ Created admin user
# 4. ✅ Tested full application flow
