# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/sscexam
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password

# Redis Configuration (Optional - currently using in-memory cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT Configuration (IMPORTANT: Change in production!)
JWT_SECRET=your-secret-key-at-least-256-bits-long-change-this-in-production

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AWS S3 Configuration
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ssc-exam-files
AWS_CLOUDFRONT_DOMAIN=

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@sscexam.com
EMAIL_VERIFICATION_URL=http://localhost:3000/verify-email
EMAIL_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# Server Configuration
PORT=8080
